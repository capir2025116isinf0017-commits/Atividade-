<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <button onclick="verificar()">Mostrar Números</button>

  <div id="resultado"></div>

  <script>
    function verificar() {
      let texto = "";

      for (let i = 1; i <= 10; i++) {
        texto += i + "<br>";
      }

      document.getElementById("resultado").innerHTML = texto;
    }
  </script>
</body>
</html>
